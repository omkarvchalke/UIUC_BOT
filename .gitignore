# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Env files (never commit secrets) ---
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# --- Data / generated artifacts ---
ingestion/data/raw/*
ingestion/data/processed/*
ingestion/data/chunks/*
ingestion/data/chroma/
!ingestion/data/raw/.gitkeep
!ingestion/data/processed/.gitkeep
!ingestion/data/chunks/.gitkeep

# Feedback logs (may accumulate local usage data)
backend/data/feedback.jsonl

# --- OS / Editor ---
.DS_Store
.vscode/
.idea/
*.swp

# --- Docker ---
*.pid
