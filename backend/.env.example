# Backend runtime config. Copy to `backend/.env` for local (non-docker) dev.
# Inside docker-compose, these are injected as environment variables instead.

APP_NAME=IlliniGuide AI
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# --- LLM (Groq) ---
GROQ_API_KEY=
# meta-llama/llama-4-scout-17b-16e-instruct: chosen after actually comparing
# rate limits across candidates on this account (response headers, not just
# published numbers). What matters for RAG isn't requests-per-minute, it's
# *tokens*-per-minute, since our prompts carry several retrieved chunks of
# context: llama-3.1-8b-instant looked like the obvious "higher quota" choice
# from its 14,400 req/min limit, but its 6,000 TPM is actually *lower* than
# llama-3.3-70b-versatile's 12,000, and it hit real 429s + 18-21s SDK retry
# backoffs running our actual eval harness. Llama 4 Scout's 30,000 TPM (2.5x
# llama-3.3-70b-versatile) has real headroom for context-heavy prompts, and
# verified to produce correctly-formatted, correctly-grounded output on our
# real JSON-mode RAG prompt (both a fully-supported case and a genuinely
# unanswerable one) before switching.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Local embeddings (no paid API) ---
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=illiniguide_documents

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://illiniguide:change-me@localhost:5432/illiniguide
