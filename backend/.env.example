# Backend runtime config. Copy to `backend/.env` for local (non-docker) dev.
# Inside docker-compose, these are injected as environment variables instead.

APP_NAME=IlliniGuide AI
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# --- LLM (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Local embeddings (no paid API) ---
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=illiniguide_documents

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://illiniguide:change-me@localhost:5432/illiniguide
