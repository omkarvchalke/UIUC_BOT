# --- Chat generation provider ---
# One of: groq | openai | google | openrouter
# Groq is the default: fast, and has a genuinely free tier (no credit card)
# at https://console.groq.com/keys. See README "AI Stack" for why.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

GROQ_API_KEY=

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Only needed if LLM_PROVIDER=google (Gemini's OpenAI-compatible endpoint;
# also has a genuinely free tier as of this writing)
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Only needed if LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings ---
# Runs locally via sentence-transformers — no API key, no per-token cost.
# "local" is the only implemented provider right now.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- Vector store ---
VECTOR_DB=chromadb
CHROMA_DB_PATH=../ingestion/data/chroma

# --- API ---
CORS_ORIGINS=http://localhost:5173
